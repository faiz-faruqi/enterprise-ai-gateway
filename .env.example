# ─────────────────────────────────────────────────────────────
# Local-First Hybrid AI Platform — Environment Configuration
# Copy this file to .env and replace all placeholder values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Inference: Local (Ollama) ─────────────────────────────────
# Base URL for the Ollama node. Can be local or a LAN address
# if running Ollama on a separate Windows node (see ADR 0003).
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma2:9b

# ── Inference: Cloud (OpenRouter) ────────────────────────────
# Obtain a key at https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Vector Store (Qdrant) ────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=enterprise-docs

# ── Cache (Redis) ────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# TTL in seconds for cached responses (default: 1 hour)
CACHE_TTL_SECONDS=3600

# ── Embedding ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Application ──────────────────────────────────────────────
LOG_LEVEL=info
# Top-k document chunks to retrieve per query
RETRIEVAL_TOP_K=5

# ── Workflow Automation (n8n) ────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme
