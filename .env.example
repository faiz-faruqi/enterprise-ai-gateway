# ─────────────────────────────────────────────────────────────────────────────
# Local-First Hybrid AI Platform — Environment Configuration
# Copy this file to .env and replace all placeholder values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment Mode ──────────────────────────────────────────────────────────
# Set to "true" on Railway demo. Uses OpenRouter for both local and cloud tiers.
# The UI will display a "Demo note" banner explaining the substitution.
DEMO_MODE=false

# ── Vector Store Backend ─────────────────────────────────────────────────────
# "qdrant"    — local Qdrant container (default for Docker Compose dev)
# "pgvector"  — Neon PostgreSQL with pgvector extension (Railway demo)
VECTOR_STORE=qdrant

# ── Vector Store: Qdrant (local dev) ─────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=enterprise-docs

# ── Vector Store: Neon pgvector (Railway demo) ───────────────────────────────
# Obtain from Neon dashboard → Connection string
# Must enable pgvector extension: CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ── Cache: Redis ─────────────────────────────────────────────────────────────
# Railway managed Redis provides REDIS_URL as a full connection string.
# For local Docker Compose, use REDIS_HOST + REDIS_PORT instead.
# REDIS_URL takes priority when both are set.
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
# TTL in seconds for cached LLM responses (default: 1 hour)
CACHE_TTL_SECONDS=3600

# ── Inference: Local (Ollama) ─────────────────────────────────────────────────
# Base URL for the Ollama node. Can be local or a LAN address
# if running Ollama on a separate machine (see docs/adr/0003).
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma2:9b

# ── Inference: Cloud (OpenRouter) ────────────────────────────────────────────
# Obtain a free API key at https://openrouter.ai
# In DEMO_MODE, this is used for BOTH local and cloud inference tiers.
OPENROUTER_API_KEY=your-openrouter-api-key-here
# For demo: mistralai/mistral-7b-instruct (free tier)
# For production: openai/gpt-4o-mini or anthropic/claude-3-haiku
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
RETRIEVAL_TOP_K=5

# ── Cost Budget (Phase 3 — FinOps) ───────────────────────────────────────────
# Set to 0 or leave unset to disable budget enforcement.
# When exceeded, the Decision Engine downgrades to cheaper model tiers.
BUDGET_DAILY_USD=0
BUDGET_MONTHLY_USD=0

# ── Admin ────────────────────────────────────────────────────────────────────
# Required for DELETE /ingest/flush-cache (X-Admin-Key header)
ADMIN_KEY=change-me-to-a-secure-random-string

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Set to your Railway backend service URL for production
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Workflow Automation (n8n) — optional, local dev only ─────────────────────
# N8N_USER=admin
# N8N_PASSWORD=changeme
