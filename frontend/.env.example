# Backend API URL — set to your Railway backend service URL for deployment
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Authentication (NextAuth) ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
# App URL (http://localhost:3000 locally; your Railway frontend URL in prod)
NEXTAUTH_URL=http://localhost:3000

# Demo credentials for the sign-in page
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123
# Leave blank to disable the access-code gate; set a value to require it
# (the access code is provided to reviewers via LinkedIn — see CLAUDE.md)
DEMO_ACCESS_CODE=
